# GdexSkill Environment Variables

# Required: Gbot Backend API base URL
GDEX_API_URL=https://trade-api.gemach.io

# Optional: API key for authenticated requests
# Use one of the pre-configured shared keys (see GDEX_API_KEYS in @gdexsdk/gdex-skill)
GDEX_API_KEY=3f6c9e12-7b41-4c2a-9d5e-1a8f3b7e6c90

# Optional: Request timeout in milliseconds (default: 30000)
GDEX_TIMEOUT=30000

# Optional: Max retry attempts on failure (default: 3)
GDEX_MAX_RETRIES=3

# Optional: Enable debug logging (default: false)
GDEX_DEBUG=false

# Optional: Custom User-Agent string
GDEX_USER_AGENT=

# Wallet credentials (for auth signing)
# EVM private key (hex, with or without 0x prefix)
EVM_PRIVATE_KEY=

# Solana private key (base58 encoded)
SOLANA_PRIVATE_KEY=
