# GdexSkill Environment Variables

# Required: Gbot Backend API base URL
GDEX_API_URL=https://trade-api.gemach.io/v1

# Optional: API key for authenticated requests
# Use one of the pre-configured shared keys (see GDEX_API_KEYS in @gdexsdk/gdex-skill)
GDEX_API_KEY=9b4e1c73-6a2f-4d88-b5c9-3e7a2f1d6c54
# Optional: Both shared API keys (comma-separated) for rotation/failover
GDEX_API_KEYS=9b4e1c73-6a2f-4d88-b5c9-3e7a2f1d6c54,2c8f0a91-5d34-4e7b-9a62-f1c3d8e4b705

# Optional: Request timeout in milliseconds (default: 30000)
GDEX_TIMEOUT=30000

# Optional: Max retry attempts on failure (default: 3)
GDEX_MAX_RETRIES=3

# Optional: Enable debug logging (default: false)
GDEX_DEBUG=false

# Optional: Custom User-Agent string
GDEX_USER_AGENT=

# ── Wallet credentials (for auth signing) ──────────────────────────
# EVM private key (hex, with or without 0x prefix)
EVM_PRIVATE_KEY=

# Solana private key (base58 encoded)
SOLANA_PRIVATE_KEY=

# ── Managed-Custody Flow ────────────────────────────────────────────
# Control wallet address used as userId in managed custody
GDEX_CONTROL_WALLET=

# Session private key (hex, 0x-prefixed) — reuse across requests
# If empty, a new keypair is generated (requires sign_in)
GDEX_SESSION_PRIVATE=

# Chain ID for managed trades (900=Solana, 101=Sui, or numeric EVM chain IDs)
GDEX_MANAGED_CHAIN_ID=900

# Token address for managed trade
GDEX_TOKEN_ADDRESS=

# Trade amount (in smallest unit / wei)
GDEX_TRADE_AMOUNT=

# Set to YES to submit real trades (default: dry-run)
CONFIRM_LIVE_TRADE=
